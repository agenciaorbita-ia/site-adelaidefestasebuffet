---
import { Image } from "astro:assets";
import logo from "../assets/img/logo-dourado.png";

const year = new Date().getFullYear();
---

<footer class="bg-azul py-12 text-prata/70">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 text-center md:flex-row md:justify-between md:text-left">
    <Image src={logo} alt="Adelaide Festas & Buffet" class="h-14 w-auto" widths={[180, 260]} />

    <div class="flex flex-col items-center gap-1 text-sm md:items-end">
      <a
        href="https://wa.me/5531995406622"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-dourado"
      >
        (31) 99540-6622
      </a>
      <a
        href="https://instagram.com/adelaidefestasebuffet"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-dourado"
      >
        @adelaidefestasebuffet
      </a>
    </div>
  </div>

  <p class="mt-8 text-center text-xs text-prata/40">
    © {year} Adelaide Festas & Buffet. Todos os direitos reservados.
  </p>
</footer>
