---
import { Image } from "astro:assets";
import heroImg from "../assets/img/hero-buffet.jpg";

const whatsapp = "https://wa.me/5531995406622?text=Ol%C3%A1!%20Vim%20pelo%20site%20e%20gostaria%20de%20saber%20mais%20sobre%20os%20pacotes.";
---

<section class="relative flex min-h-screen items-end overflow-hidden bg-azul">
  <Image
    src={heroImg}
    alt="Mesa de buffet com decoração elegante da Adelaide Festas & Buffet"
    class="absolute inset-0 h-full w-full object-cover"
    widths={[640, 1024, 1600, 2000]}
    sizes="100vw"
    quality={80}
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-azul via-azul/70 to-azul/30"></div>
  <div class="absolute inset-0 bg-azul/20"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-24 pt-40">
    <p class="mb-4 text-sm uppercase tracking-[0.3em] text-dourado">
      Festas & Buffet · Belo Horizonte
    </p>
    <h1 class="font-display max-w-3xl text-4xl font-medium leading-tight text-prata sm:text-5xl md:text-6xl">
      Onde o amor é celebrado, cuidamos de cada detalhe
    </h1>
    <p class="mt-6 max-w-xl text-base leading-relaxed text-prata/85 md:text-lg">
      Buffet completo para casamentos, debutantes, festas infantis e confraternizações — salão, decoração, bebidas, equipe e cortesias inclusas. Há 8 anos transformando celebrações em memórias.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href={whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-dourado px-8 py-3 text-sm font-medium tracking-wide text-azul transition hover:bg-dourado-claro"
      >
        Falar no WhatsApp
      </a>
      <a
        href="#diferenciais"
        class="rounded-full border border-prata/40 px-8 py-3 text-sm tracking-wide text-prata transition hover:border-dourado hover:text-dourado"
      >
        Ver o que está incluso
      </a>
    </div>
  </div>
</section>
