---
import { Image } from "astro:assets";
import g1 from "../assets/img/galeria-1.jpg";
import g2 from "../assets/img/galeria-2.jpg";
import g3 from "../assets/img/galeria-3.jpg";
import g4 from "../assets/img/galeria-4.jpg";
import g5 from "../assets/img/galeria-5.jpg";
import g6 from "../assets/img/galeria-6.jpg";

const fotos = [g1, g2, g3, g4, g5, g6];
---

<section id="galeria" class="bg-prata py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-dourado">
        Galeria
      </p>
      <h2 class="font-display text-3xl font-medium text-azul md:text-4xl">
        Momentos que já celebramos
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-2 gap-4 md:grid-cols-3">
      {
        fotos.map((foto) => (
          <div class="aspect-square overflow-hidden rounded-lg">
            <Image
              src={foto}
              alt="Mesa de buffet da Adelaide Festas & Buffet"
              class="h-full w-full object-cover transition duration-500 hover:scale-105"
              widths={[300, 500, 700]}
              sizes="(min-width: 768px) 33vw, 50vw"
            />
          </div>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm text-azul/60">
      Veja mais no Instagram
      <a
        href="https://instagram.com/adelaidefestasebuffet"
        target="_blank"
        rel="noopener noreferrer"
        class="text-azul underline decoration-dourado underline-offset-4"
        >@adelaidefestasebuffet</a
      >
    </p>
  </div>
</section>
