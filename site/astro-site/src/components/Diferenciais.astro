---
const itens = [
  {
    titulo: "Bebidas inclusas",
    texto:
      "Duas opções de sucos, refrigerante e água para atender seus convidados com conforto.",
  },
  {
    titulo: "Equipe e estrutura completas",
    texto:
      "Profissionais qualificados e todos os vasilhames inclusos, assegurando um serviço organizado e tranquilo do início ao fim.",
  },
  {
    titulo: "Cortesia especial",
    texto:
      "Bolo de corte + 200 doces, um cuidado a mais para adoçar seu momento e encantar seus convidados.",
  },
];
---

<section id="diferenciais" class="bg-azul py-24 text-prata">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-dourado">
        Tudo incluso
      </p>
      <h2 class="font-display text-3xl font-medium md:text-4xl">
        Uma entrega completa, para você aproveitar sem preocupações
      </h2>
      <p class="mt-4 text-prata/75">
        Ao escolher os pacotes Adelaide Festas & Buffet, você garante não
        apenas salão, buffet e decoração, mas também acompanhamentos e
        cortesias que fazem toda a diferença no seu evento.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        itens.map((item) => (
          <div class="rounded-lg border border-prata/15 bg-prata/5 p-8 text-center transition hover:border-dourado/50">
            <h3 class="font-display text-xl text-dourado">{item.titulo}</h3>
            <p class="mt-4 text-sm leading-relaxed text-prata/75">
              {item.texto}
            </p>
          </div>
        ))
      }
    </div>

    <p class="mt-12 text-center text-sm text-prata/60">
      Valores para eventos realizados de segunda a domingo, exceto sábados.
    </p>
  </div>
</section>
